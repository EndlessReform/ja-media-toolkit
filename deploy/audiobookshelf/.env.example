# Pin upgrades deliberately. Verified against the official GHCR image on
# 2026-06-22.
AUDIOBOOKSHELF_VERSION=2.35.1
AUDIOBOOKSHELF_PORT=13378

# These directories must remain on storage local to the Docker VM. In
# particular, do not put Audiobookshelf's SQLite-backed config on NFS.
AUDIOBOOKSHELF_CONFIG_DIR=./config
AUDIOBOOKSHELF_METADATA_DIR=./metadata

# /mnt/magi06 is the host storage bind mount. The derived library is rooted at
# media/derived-audio beneath it.
ANIME_AUDIO_LIBRARY_DIR=/mnt/magi06/media/derived-audio
