{
  "description": "Availability, refresh validation, corpus size, and scrape health for the ja-media-services deployment.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Prometheus's current view of every discovered target in this deployment.",
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": {"color": "red", "text": "DOWN"},
                "1": {"color": "green", "text": "UP"}
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 16, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "up{deployment=\"ja-media-services\"}",
          "legendFormat": "{{service}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Services up",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Fraction of discovered service targets currently reachable by Prometheus.",
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "orange", "value": 0.8},
              {"color": "green", "value": 1}
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 8, "x": 16, "y": 0},
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(up{deployment=\"ja-media-services\"}) / count(up{deployment=\"ja-media-services\"})",
          "legendFormat": "availability",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Current availability",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "A value of 1 means the database currently being served passed its rebuild validation. These metrics do not yet expose rebuild age.",
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": {"color": "red", "text": "FAILED"},
                "1": {"color": "green", "text": "VALID"}
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 24, "x": 0, "y": 5},
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "anime_crosswalk_last_rebuild_success{deployment=\"ja-media-services\"}",
          "legendFormat": "anime-crosswalk",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "kitsunekko_subtitles_last_rebuild_success{deployment=\"ja-media-services\"}",
          "legendFormat": "kitsunekko-subtitles",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "Refresh artifact validation",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Historical reachability makes brief outages and scrape failures visible.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false
          },
          "max": 1,
          "min": 0
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 14, "x": 0, "y": 10},
      "id": 4,
      "options": {
        "legend": {
          "calcs": ["lastNotNull"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {"mode": "multi", "sort": "none"}
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "up{deployment=\"ja-media-services\"}",
          "legendFormat": "{{service}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Service availability history",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Scrape latency for each service target. Sustained growth can reveal a service becoming expensive or stuck.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 10, "x": 14, "y": 10},
      "id": 5,
      "options": {
        "legend": {
          "calcs": ["lastNotNull", "max"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "scrape_duration_seconds{deployment=\"ja-media-services\"}",
          "legendFormat": "{{service}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Prometheus scrape duration",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Current validated corpus sizes. Unexpected drops are often the first visible sign of a bad upstream refresh.",
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 10, "x": 0, "y": 18},
      "id": 6,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "anime_crosswalk_rows_total{deployment=\"ja-media-services\"}",
          "legendFormat": "crosswalk anime",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "kitsunekko_subtitle_files_total{deployment=\"ja-media-services\"}",
          "legendFormat": "subtitle files",
          "range": true,
          "refId": "B"
        },
        {
          "editorMode": "code",
          "expr": "kitsunekko_subtitle_lookups_total{deployment=\"ja-media-services\"}",
          "legendFormat": "subtitle lookups",
          "range": true,
          "refId": "C"
        }
      ],
      "title": "Current corpus sizes",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Crosswalk lookup rows by source identifier. The all series is the total lookup table size.",
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 8, "x": 10, "y": 18},
      "id": 7,
      "options": {
        "displayMode": "gradient",
        "minVizHeight": 10,
        "minVizWidth": 0,
        "namePlacement": "auto",
        "orientation": "horizontal",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "showUnfilled": true,
        "sizing": "auto",
        "valueMode": "color"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "anime_crosswalk_lookups_total{deployment=\"ja-media-services\"}",
          "legendFormat": "{{source}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Crosswalk lookup coverage",
      "type": "bargauge"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Number of metric samples returned by each target. A sudden change can expose a broken or unexpectedly expanded metrics endpoint.",
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 6, "x": 18, "y": 18},
      "id": 8,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "scrape_samples_scraped{deployment=\"ja-media-services\"}",
          "legendFormat": "{{service}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Samples per scrape",
      "type": "stat"
    },
    {
      "description": "This revision intentionally uses only existing metrics. AniList Search is absent because it does not expose /metrics yet.",
      "gridPos": {"h": 4, "w": 24, "x": 0, "y": 24},
      "id": 9,
      "options": {
        "content": "### Current monitoring boundary\n\nAniList Search is not represented because it does not yet expose Prometheus metrics. Refresh panels show current artifact validity, not refresh age; timestamps and failure counters can be added after the first dashboard revisions reveal what is operationally useful.",
        "mode": "markdown"
      },
      "title": "Read this before trusting the dashboard",
      "type": "text"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["ja-media", "services"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Prometheus",
        "multi": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      }
    ]
  },
  "time": {"from": "now-24h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "ja-media services",
  "uid": "ja-media-services",
  "version": 1,
  "weekStart": ""
}
