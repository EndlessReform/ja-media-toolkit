# Copy to .env on the GPU host and edit only machine-local values.

MODEL_ID=Qwen/Qwen3-ForcedAligner-0.6B
SERVER_PORT=8000

# vLLM does not publish the optional audio dependencies in its OpenAI image.
# This deployment builds a tiny derived image that installs vllm[audio] at the
# matching version. Keep the base tag and audio extra version in lockstep.
VLLM_BASE_IMAGE=vllm/vllm-openai:v0.24.0
VLLM_AUDIO_EXTRA_VERSION=0.24.0
VLLM_AUDIO_IMAGE=qwen3-forced-aligner-vllm:0.24.0-audio

# Optional. Required for gated/private model downloads.
HF_TOKEN=
HF_HOME=/var/lib/qwen3-forced-aligner/huggingface

# Keep this at 1 for the first proof-of-value pass. Raise only after the client
# validates result extraction and the GPU has headroom.
MAX_NUM_SEQS=1
GPU_MEMORY_UTILIZATION=0.90

# Extra args are appended verbatim by scripts/run-docker.sh.
EXTRA_VLLM_ARGS=
